---
import StructuredData from '../components/StructuredData.astro';
import {
  CONFERENCE_SHORT,
  SEO_DESCRIPTION,
  SEO_KEYWORDS,
  SEO_TITLE,
  SITE_NAME,
} from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = SEO_TITLE,
  description = SEO_DESCRIPTION,
} = Astro.props;

const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';
const canonicalUrl = siteUrl || Astro.url.href;
const ogImage = siteUrl ? `${siteUrl}/assets/hero-mobile.webp` : '/assets/hero-mobile.webp';
---

<!doctype html>
<html lang="en-PH">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={SEO_KEYWORDS} />
    <meta name="author" content="CE-Logic, Inc." />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    <meta name="googlebot" content="index, follow" />
    <meta name="theme-color" content="#03153a" />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="apple-mobile-web-app-title" content={CONFERENCE_SHORT} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta property="og:locale" content="en_PH" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="18th CE-Logic National Conference | CE Logic Natcon 2026" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link
      rel="preload"
      as="image"
      href="/assets/hero.webp"
      type="image/webp"
      imagesrcset="/assets/hero.webp 1600w, /assets/hero@2x.webp 2400w"
      imagesizes="100vw"
      media="(min-width: 641px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/assets/hero-mobile.webp"
      type="image/webp"
      imagesrcset="/assets/hero-mobile.webp 828w, /assets/hero-mobile@2x.webp 1242w"
      imagesizes="100vw"
      media="(max-width: 640px)"
      fetchpriority="high"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <StructuredData />
  </head>
  <body>
    <slot />
    <script>
      import { initCountdown } from '../scripts/countdown.ts';
      initCountdown();
    </script>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    background: #03153a;
  }
  body {
    margin: 0;
    padding: 0;
    background: #03153a;
    font-family: Roboto, "Segoe UI", system-ui, -apple-system, Arial, sans-serif;
  }
</style>