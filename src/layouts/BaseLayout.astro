---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CE-Logic National Conference 2026',
  description = '18th CE-Logic National Conference · July 30-31, 2026. Live stream access for library leaders, partners, and higher education stakeholders.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#03153a" />
    <link rel="icon" type="image/webp" href="/assets/ce-mark.webp" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="preload"
      as="image"
      href="/assets/hero.webp"
      type="image/webp"
      imagesrcset="/assets/hero.webp 1920w, /assets/hero@2x.webp 3840w"
      imagesizes="100vw"
      media="(min-width: 641px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      href="/assets/hero-mobile.webp"
      type="image/webp"
      imagesrcset="/assets/hero-mobile.webp 1080w, /assets/hero-mobile@2x.webp 2160w"
      imagesizes="100vw"
      media="(max-width: 640px)"
      fetchpriority="high"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;600;700;900&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    background: #03153a;
  }
  body {
    margin: 0;
    padding: 0;
    background: #03153a;
    font-family: Roboto, "Segoe UI", system-ui, -apple-system, Arial, sans-serif;
  }
</style>
