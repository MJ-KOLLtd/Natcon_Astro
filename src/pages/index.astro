---
import BaseLayout from '../layouts/BaseLayout.astro';
import FigmaLanding from '../components/FigmaLanding.astro';
import Secondary from '../components/Secondary.astro';
import Highlights from '../components/Highlights.astro';
import Theme from '../components/Theme.astro';
import Stream from '../components/Stream.astro';
import Speakers from '../components/Speakers.astro';
import Experience from '../components/Experience.astro';
import Stats from '../components/Stats.astro';
import Partners from '../components/Partners.astro';
import FAQ from '../components/FAQ.astro';
import FinalCta from '../components/FinalCta.astro';
import '../styles/figma-layout.css';
import '../styles/natcon.css';
import '../styles/natcon-theme.css';
---

<BaseLayout
  title="18th CE-Logic National Conference | NATCON 2026"
  description="18th CE-Logic National Conference — July 30-31, 2026 at Seda Vertis North, Quezon City. Empowering Data Champions for Sustainable, Future-Ready, and Globally Competitive Education."
>
  <div id="cel-natcon-2026">
    <FigmaLanding />

    <div class="cel-nc">
      <div class="nc-page-bg" aria-hidden="true">
        <div class="nc-page-bg-shade"></div>
      </div>

      <div class="nc-page-stack">
        <Secondary />
        <Highlights />
        <Theme />
        <Stream />
        <Speakers />
        <Experience />
        <Stats />
        <Partners />
        <FAQ />
        <FinalCta />
      </div>
    </div>
  </div>
</BaseLayout>