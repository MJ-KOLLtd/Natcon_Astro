---
import { CONFERENCE_SHORT, EVENT, ORGANIZER, SEO_DESCRIPTION, SITE_NAME } from '../data/site';

const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';
const pageUrl = siteUrl || Astro.url.href;
const imageUrl = siteUrl ? `${siteUrl}/assets/hero-mobile.webp` : '/assets/hero-mobile.webp';

const eventJson = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: EVENT.name,
  alternateName: EVENT.alternateName,
  description: SEO_DESCRIPTION,
  startDate: EVENT.startDate,
  endDate: EVENT.endDate,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OnlineEventAttendanceMode',
  image: [imageUrl],
  url: pageUrl,
  organizer: {
    '@type': 'Organization',
    name: ORGANIZER.name,
    url: ORGANIZER.url,
    parentOrganization: {
      '@type': 'Organization',
      name: ORGANIZER.parent,
      url: ORGANIZER.parentUrl,
    },
  },
  performer: {
    '@type': 'Organization',
    name: ORGANIZER.name,
  },
};

const websiteJson = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: `${SITE_NAME} 2026`,
  alternateName: EVENT.alternateName,
  url: pageUrl,
  description: SEO_DESCRIPTION,
  publisher: {
    '@type': 'Organization',
    name: ORGANIZER.name,
    url: ORGANIZER.url,
  },
};

const faqJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: `What is ${SITE_NAME}?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${SITE_NAME} is the CE-Logic National Conference, the annual gathering for Philippine academic library leaders, partners, and higher education stakeholders. This page is the official landing site for the 18th edition (NATCON 2026), July 30-31, 2026, with live stream access on event days.`,
      },
    },
    {
      '@type': 'Question',
      name: `How may I access the ${SITE_NAME} live stream?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `The official ${SITE_NAME} live stream is hosted on the CE-Logic Facebook page (facebook.com/celogic). The stream link activates on event days, July 30-31, 2026.`,
      },
    },
    {
      '@type': 'Question',
      name: `When is ${SITE_NAME} 2026?`,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `${SITE_NAME} 2026 takes place on July 30-31, 2026. Sessions are available via live stream on the CE-Logic Facebook page.`,
      },
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(eventJson)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteJson)} />
<script type="application/ld+json" set:html={JSON.stringify(faqJson)} />