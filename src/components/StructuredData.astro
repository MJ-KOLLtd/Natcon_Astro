---
import { CONFERENCE_SHORT, EVENT, ORGANIZER, SEO_DESCRIPTION, SITE_NAME } from '../data/site';

const siteUrl = Astro.site?.href?.replace(/\/$/, '') ?? '';
const pageUrl = siteUrl || Astro.url.href;
const imageUrl = siteUrl ? `${siteUrl}/assets/hero-mobile.webp` : '/assets/hero-mobile.webp';

const eventJson = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: EVENT.name,
  alternateName: EVENT.alternateName,
  description: SEO_DESCRIPTION,
  startDate: EVENT.startDate,
  endDate: EVENT.endDate,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/MixedEventAttendanceMode',
  image: [imageUrl],
  url: pageUrl,
  location: {
    '@type': 'Place',
    name: EVENT.venue,
    address: {
      '@type': 'PostalAddress',
      addressLocality: EVENT.locality,
      addressRegion: EVENT.region,
      addressCountry: EVENT.country,
    },
  },
  organizer: {
    '@type': 'Organization',
    name: ORGANIZER.name,
    url: ORGANIZER.url,
    parentOrganization: {
      '@type': 'Organization',
      name: ORGANIZER.parent,
      url: ORGANIZER.parentUrl,
    },
  },
  performer: {
    '@type': 'Organization',
    name: ORGANIZER.name,
  },
};

const websiteJson = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: `${SITE_NAME} 2026`,
  alternateName: EVENT.alternateName,
  url: pageUrl,
  description: SEO_DESCRIPTION,
  publisher: {
    '@type': 'Organization',
    name: ORGANIZER.name,
    url: ORGANIZER.url,
  },
};

const faqJson = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is CE Logic Natcon?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CE Logic Natcon is the CE-Logic National Conference — the flagship annual gathering for Philippine academic library leaders, partners, and higher education stakeholders. The 2026 edition is the 18th CE-Logic National Conference (NATCON 2026), held July 30-31, 2026 at Seda Vertis North, Quezon City.',
      },
    },
    {
      '@type': 'Question',
      name: 'How may I access the CE Logic Natcon live stream?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The official CE Logic Natcon live stream is hosted on the CE-Logic Facebook page (facebook.com/celogic). The stream link activates on event days, July 30-31, 2026.',
      },
    },
    {
      '@type': 'Question',
      name: 'When and where is CE Logic Natcon 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CE Logic Natcon 2026 takes place on July 30-31, 2026 at Seda Vertis North, Quezon City, Metro Manila. Sessions are also available via live stream.',
      },
    },
  ],
};
---

<script type="application/ld+json" set:html={JSON.stringify(eventJson)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteJson)} />
<script type="application/ld+json" set:html={JSON.stringify(faqJson)} />