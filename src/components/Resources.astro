---
import { resourceDriveLinks } from '../data/conferenceResources';
---

<section class="nc-section is-soft nc-resources" id="cel-nc-resources" aria-label="Conference resources">
  <div class="nc-container">
    <h2 class="nc-h2">Conference Resources</h2>
    <p class="nc-lead nc-resources-lead">
      Open the official conference program, or access sponsor and speaker
      materials on Google Drive. Select a resource below to view or download.
    </p>

    <div class="nc-resources-drive-grid">
      {
        resourceDriveLinks.map((item) => (
          <a
            class:list={[
              'nc-resources-drive-card',
              item.tone === 'gold' && 'is-videos',
              item.tone === 'blue' && 'is-brochures',
              item.tone === 'green' && 'is-program',
            ]}
            id={`cel-nc-resources-${item.id}`}
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="nc-resources-drive-copy">
              <span
                class:list={[
                  'nc-tier-label',
                  item.tone === 'gold' && 'is-gold',
                  item.tone === 'blue' && 'is-blue',
                  item.tone === 'green' && 'is-green',
                ]}
              >
                {item.label}
              </span>
            </span>
            <span class="nc-resources-drive-action" aria-hidden="true">
              <span class="nc-resources-drive-action-label">{item.actionLabel}</span>
              <span class="nc-resources-drive-arrow"></span>
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>