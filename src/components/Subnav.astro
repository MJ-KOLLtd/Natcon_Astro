---
// Sticky conference subnav
---

<div class="nc-subnav">
  <div class="nc-container nc-subnav-inner">
    <a
      class="nc-subnav-brand"
      href="https://ceals.ph/our-brands/brands-ce-logic/"
      aria-label="CE-Logic brand page"
      target="_blank"
      rel="noopener noreferrer"
    >
      <img
        class="nc-subnav-logo"
        src="/assets/ce-logic-logo.webp"
        alt="CE-Logic"
        width="200"
        height="38"
      />
      <span class="nc-subnav-brand-text">
        <strong>
          <span class="nc-ce">NatCon</span>
          <span class="nc-logic">2026</span>
        </strong>
        <span>July 30-31, 2026</span>
      </span>
    </a>
    <nav class="nc-subnav-menu" aria-label="Conference sections">
      <span class="nc-live-chip">
        <span class="nc-live-dot" aria-hidden="true"></span>
        Event-day stream
      </span>
      <a class="nc-subnav-link hide-md" href="#cel-nc-stream">Stream</a>
      <a class="nc-subnav-link hide-md" href="#cel-nc-speakers">Speakers</a>
      <a class="nc-subnav-link hide-md" href="#cel-nc-partners">Partners</a>
      <a class="nc-subnav-link hide-md" href="#cel-nc-experience">Program</a>
      <a class="nc-btn nc-btn-gold" href="#cel-nc-stream">Live stream</a>
    </nav>
  </div>
</div>
