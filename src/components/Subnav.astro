---
import { resourceNavLinks } from '../data/conferenceResources';

interface Props {
  homeHref?: string;
}

const { homeHref = '#hero' } = Astro.props;

const navLinks = [
  { label: 'Highlights', href: '#cel-nc-highlights' },
  { label: 'Livestream', href: '#cel-nc-stream', showCountdown: true },
  { label: 'About', href: '#cel-nc-about' },
  { label: 'Stream Coverage', href: '#cel-nc-what-streamed' },
  { label: 'Theme', href: '#cel-nc-theme' },
  { label: 'Speakers', href: '#cel-nc-speakers' },
  { label: 'Partners', href: '#cel-nc-partners' },
];

const resourceLinks = resourceNavLinks;
---

<header class="nc-subnav" data-nc-subnav role="banner">
  <div class="nc-container nc-subnav-inner">
    <a
      class="nc-subnav-brand"
      href={homeHref}
      aria-label="NATCON 2026 home"
    >
      <img
        class="nc-subnav-logo"
        src="/assets/ce-logic-logo-on-dark.webp"
        alt="CE-Logic"
        width="148"
        height="32"
      />
      <span class="nc-subnav-brand-text">NATCON 2026 · July 30, 31, 2026</span>
    </a>

    <div class="nc-subnav-end">
      <button
        type="button"
        class="nc-menu-toggle"
        data-nc-menu-toggle
        aria-expanded="false"
        aria-controls="nc-subnav-menu"
        aria-label="Open menu"
      >
        <span class="nc-menu-toggle-box" aria-hidden="true">
          <span class="nc-menu-toggle-bar"></span>
          <span class="nc-menu-toggle-bar"></span>
          <span class="nc-menu-toggle-bar"></span>
        </span>
      </button>

      <nav class="nc-subnav-menu" id="nc-subnav-menu" aria-label="Conference sections">
        {
          navLinks.map((item) => (
            <a
              class:list={[
                'nc-subnav-link',
                item.showCountdown && 'nc-subnav-link--livestream',
              ]}
              href={item.href}
            >
              {item.label}
              {item.showCountdown && (
                <span
                  class="nc-subnav-countdown"
                  data-nc-countdown-compact
                  aria-live="polite"
                />
              )}
            </a>
          ))
        }

        <div class="nc-subnav-resources" data-nc-resources>
          <button
            type="button"
            class="nc-subnav-link nc-subnav-resources-toggle"
            aria-expanded="false"
            aria-controls="nc-subnav-resources-panel"
            data-nc-resources-toggle
          >
            Resources
            <span class="nc-subnav-caret" aria-hidden="true"></span>
          </button>
          <div
            class="nc-subnav-resources-panel"
            id="nc-subnav-resources-panel"
            hidden
            role="menu"
          >
            {
              resourceLinks.map((item) => (
                <a
                  class="nc-subnav-resources-item"
                  href={item.href}
                  role="menuitem"
                >
                  <span>{item.label}</span>
                </a>
              ))
            }
          </div>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  function initSubnav() {
    const root = document.querySelector('[data-nc-subnav]');
    if (!root || root.dataset.ready === '1') return;
    root.dataset.ready = '1';

    const toggle = root.querySelector('[data-nc-menu-toggle]');
    const menu = root.querySelector('#nc-subnav-menu');
    if (!toggle || !menu) return;

    const resources = root.querySelector('[data-nc-resources]');
    const resourcesToggle = root.querySelector('[data-nc-resources-toggle]');
    const resourcesPanel = root.querySelector('#nc-subnav-resources-panel');

    const mq = window.matchMedia('(max-width: 1024px)');

    function setResourcesOpen(open) {
      if (!resources || !resourcesToggle || !resourcesPanel) return;
      resources.classList.toggle('is-open', open);
      resourcesToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) resourcesPanel.removeAttribute('hidden');
      else resourcesPanel.setAttribute('hidden', '');
    }

    function setOpen(open) {
      root.classList.toggle('is-menu-open', open);
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      if (!open) setResourcesOpen(false);
      if (!mq.matches) {
        menu.removeAttribute('hidden');
        return;
      }
      if (open) menu.removeAttribute('hidden');
      else menu.setAttribute('hidden', '');
    }

    function close() {
      setOpen(false);
    }

    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      setOpen(!open);
    });

    if (resourcesToggle) {
      resourcesToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const open = resourcesToggle.getAttribute('aria-expanded') === 'true';
        setResourcesOpen(!open);
      });
    }

    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        if (mq.matches) close();
        setResourcesOpen(false);
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && root.classList.contains('is-menu-open')) {
        close();
        toggle.focus();
      }
      if (e.key === 'Escape' && resources?.classList.contains('is-open')) {
        setResourcesOpen(false);
        resourcesToggle?.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (resources && !resources.contains(e.target)) {
        setResourcesOpen(false);
      }
      if (!root.classList.contains('is-menu-open')) return;
      if (!root.contains(e.target)) close();
    });

    function onViewport() {
      if (mq.matches) {
        setOpen(false);
      } else {
        root.classList.remove('is-menu-open');
        toggle.setAttribute('aria-expanded', 'false');
        toggle.setAttribute('aria-label', 'Open menu');
        menu.removeAttribute('hidden');
        setResourcesOpen(false);
      }
    }

    onViewport();
    if (typeof mq.addEventListener === 'function') {
      mq.addEventListener('change', onViewport);
    } else {
      mq.addListener(onViewport);
    }
  }

  function initCountdownCompact() {
    const TARGET = new Date('2026-07-30T08:00:00+08:00').getTime();
    const nodes = document.querySelectorAll('[data-nc-countdown-compact]');
    if (!nodes.length) return;

    function pad(n) {
      return String(n).padStart(2, '0');
    }

    function tick() {
      const remaining = TARGET - Date.now();
      nodes.forEach((node) => {
        if (remaining <= 0) {
          node.textContent = 'Live now';
          node.classList.add('is-live');
          return;
        }
        const days = Math.floor(remaining / 86400000);
        const hours = Math.floor((remaining % 86400000) / 3600000);
        const mins = Math.floor((remaining % 3600000) / 60000);
        node.textContent = `${days}d ${pad(hours)}h ${pad(mins)}m`;
      });
    }

    tick();
    if (!window.__ncCountdownCompact) {
      window.__ncCountdownCompact = window.setInterval(tick, 1000);
    }
  }

  initSubnav();
  initCountdownCompact();
  document.addEventListener('astro:page-load', () => {
    initSubnav();
    initCountdownCompact();
  });
</script>