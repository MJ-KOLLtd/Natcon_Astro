---
import { SITE_NAME } from '../data/site';

const highlights = [
  { value: '18th', label: 'National Conference' },
  { value: '7.5', label: 'CPD Units for Librarians' },
  { value: '2', label: 'Conference Days' },
  { value: '12+', label: 'Featured Speakers' },
];
---

<section class="nc-section is-soft nc-conference-highlights" id="cel-nc-highlights">
  <div class="nc-container">
    <h2 class="nc-h2">{SITE_NAME} Highlights</h2>
    <p class="nc-lead" style="margin-bottom:1.5rem;">
      Welcome to the official <strong>{SITE_NAME}</strong> page for the 18th
      CE-Logic National Conference, July 30-31, 2026.
    </p>
    <div class="nc-stats nc-stats--highlights">
      {
        highlights.map((item) => (
          <div class="nc-stat">
            <strong>{item.value}</strong>
            <span>{item.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>