---
const REGISTER_URL = 'https://www.facebook.com/celogic';
---

<header class="nc-hero" id="cel-nc-home">
  <div class="nc-hero-scene" aria-hidden="true">
    <div class="nc-hero-glow"></div>
    <div class="nc-hero-curve nc-hero-curve--gold"></div>
    <div class="nc-hero-curve nc-hero-curve--gold-alt"></div>
    <div class="nc-hero-curve nc-hero-curve--white"></div>
    <div class="nc-hero-curve nc-hero-curve--blue"></div>
  </div>

  <div class="nc-container nc-hero-inner">
    <div class="nc-hero-top">
      <img
        class="nc-hero-mark"
        src="/assets/ce-mark.webp"
        alt=""
        aria-hidden="true"
        width="160"
        height="160"
        fetchpriority="high"
        decoding="async"
      />

      <div class="nc-hero-partnership">
        <p class="nc-hero-partnership-title">The University Library</p>
        <p class="nc-hero-partnership-sub">University of the Philippines Diliman</p>
      </div>

      <img
        class="nc-hero-up-seal"
        src="/assets/partner-up-library.webp"
        alt="University of the Philippines Library seal"
        width="108"
        height="108"
        loading="eager"
        decoding="async"
      />
    </div>

    <div class="nc-hero-headline">
      <h1 class="nc-hero-title">
        <span class="nc-hero-title-row">
          <span class="nc-hero-edition">18<sup>th</sup></span>
          <span class="nc-hero-brand">
            <span class="nc-hero-brand-text">CE-Logic</span>
            <span class="nc-hero-e-badge" aria-hidden="true">e</span>
          </span>
        </span>
        <span class="nc-hero-conference">National Conference</span>
      </h1>

      <p class="nc-hero-tagline">
        Empowering Data Champions for Sustainable, Future-Ready, and Globally
        Competitive Education
      </p>

      <ul class="nc-hero-meta" aria-label="Event details">
        <li>
          <svg class="nc-hero-meta-icon" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" fill="none" stroke="currentColor" stroke-width="2"></rect>
            <path d="M16 2v4M8 2v4M3 10h18" fill="none" stroke="currentColor" stroke-width="2"></path>
          </svg>
          <span>July 30-31, 2026</span>
        </li>
        <li class="nc-hero-meta-sep" aria-hidden="true"></li>
        <li>
          <svg class="nc-hero-meta-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 21s7-5.2 7-11a7 7 0 1 0-14 0c0 5.8 7 11 7 11z" fill="none" stroke="currentColor" stroke-width="2"></path>
            <circle cx="12" cy="10" r="2.5" fill="none" stroke="currentColor" stroke-width="2"></circle>
          </svg>
          <span>Quezon City, Metro Manila</span>
        </li>
      </ul>
    </div>

    <div class="nc-hero-lower">
      <div class="nc-hero-organizers">
        <div class="nc-hero-org-block">
          <p class="nc-hero-org-label is-organized">Organized by</p>
          <img
            class="nc-hero-org-logo"
            src="/assets/ce-logic-logo-on-dark.webp"
            alt="CE-Logic"
            width="220"
            height="52"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="nc-hero-org-block">
          <p class="nc-hero-org-label is-copresented">Co-presented by</p>
          <div class="nc-hero-co-logos">
            <img
              src="/assets/partner-paarl.webp"
              alt="PAARL, Philippine Association of Academic and Research Librarians"
              width="132"
              height="60"
              loading="eager"
              decoding="async"
            />
            <img
              src="/assets/partner-plai.webp"
              alt="Philippine Librarians Association, Inc."
              width="80"
              height="80"
              loading="eager"
              decoding="async"
            />
          </div>
        </div>
      </div>

      <div class="nc-hero-cta-wrap">
        <div class="nc-hero-cta-cluster">
          <div class="nc-hero-cpd-badge" aria-label="7.5 CPD Units">
            <span class="nc-hero-cpd-value">7.5</span>
            <span class="nc-hero-cpd-label">CPD Units</span>
          </div>

          <a
            class="nc-hero-register-card"
            href={REGISTER_URL}
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="nc-hero-register-title">Limited Slots Available</span>
          </a>

          <a
            class="nc-hero-scan-btn"
            href={REGISTER_URL}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Scan to register, limited slots available"
          >
            Scan me!
          </a>

          <img
            class="nc-hero-qr"
            src="/assets/register-qr.webp"
            alt="Registration QR code"
            width="132"
            height="132"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>
    </div>

    <p class="nc-hero-inquiry">For inquiries, contact your Solutions Specialist</p>
  </div>
</header>