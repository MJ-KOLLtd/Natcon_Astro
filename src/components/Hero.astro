---
import BtnArrow from './BtnArrow.astro';

const alliance = [
  {
    logo: '/assets/partner-up-library.webp',
    alt: 'University of the Philippines Library',
    name: 'UP Library',
    shape: 'round',
  },
  {
    logo: '/assets/partner-plai.webp',
    alt: 'Philippine Librarians Association, Inc.',
    name: 'PLAI',
    shape: 'round',
  },
  {
    logo: '/assets/partner-paarl.webp',
    alt: 'PAARL',
    name: 'PAARL',
    shape: 'rect',
  },
];
---

<header class="nc-hero">
  <div class="nc-hero-bg" aria-hidden="true">
    <img
      src="/assets/hero-bg.webp"
      alt=""
      width="2560"
      height="1440"
      fetchpriority="high"
      decoding="async"
    />
  </div>
  <div class="nc-container">
    <!-- Institutional partners — immediately visible -->
    <div class="nc-hero-alliance" aria-label="Institutional partners and endorsements">
      <div class="nc-hero-alliance-block">
        <p class="nc-hero-alliance-label">In partnership with</p>
        <ul class="nc-hero-alliance-logos">
          {
            alliance.slice(0, 2).map((p) => (
              <li class:list={['is-' + p.shape]}>
                <img
                  src={p.logo}
                  alt={p.alt}
                  width="112"
                  height="112"
                  loading="eager"
                  decoding="async"
                />
                <span>{p.name}</span>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="nc-hero-alliance-rule" aria-hidden="true"></div>
      <div class="nc-hero-alliance-block">
        <p class="nc-hero-alliance-label">Endorsed by</p>
        <ul class="nc-hero-alliance-logos">
          {
            alliance.slice(2).map((p) => (
              <li class:list={['is-' + p.shape]}>
                <img
                  src={p.logo}
                  alt={p.alt}
                  width="128"
                  height="112"
                  loading="eager"
                  decoding="async"
                />
                <span>{p.name}</span>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="nc-hero-meta">
      <span>July 30-31, 2026</span>
      <span>18th Edition</span>
      <span>Live stream access</span>
    </div>

    <h1 class="nc-hero-title">
      <img
        class="nc-hero-natcon"
        src="/assets/natcon-logo.webp"
        alt="18th CE-Logic National Conference"
        width="720"
        height="200"
      />
    </h1>

    <!-- Crisp HTML tagline (not a scaled raster in the logo file) -->
    <p class="nc-hero-theme">
      Empowering Data Champions for Sustainable, Future-Ready, and Globally
      Competitive Education
    </p>

    <p class="nc-hero-desc">
      A professional forum for academic library leaders advancing data-informed
      decision-making, digital transformation, and institutional competitiveness
      in higher education.
    </p>
    <div class="nc-btn-row">
      <a
        class="nc-btn nc-btn-primary"
        href="https://www.facebook.com/celogic"
        target="_blank"
        rel="noopener noreferrer"
      >
        View live stream
        <BtnArrow />
      </a>
      <a class="nc-btn nc-btn-linkish" href="#cel-nc-speakers">
        View speakers
        <BtnArrow />
      </a>
    </div>
  </div>
</header>
