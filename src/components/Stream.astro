---
/** Official CE-Logic Facebook page — stream activates on event days */
const STREAM_URL = 'https://www.facebook.com/celogic';
---

<section class="nc-section is-dark" id="cel-nc-stream">
  <div class="nc-container">
    <p class="nc-eyebrow">
      <span class="nc-live-chip" style="color:var(--nc-gold);">
        <span class="nc-live-dot"></span>
        Event-day access
      </span>
    </p>
    <h2 class="nc-h2">Live <span class="nc-em">stream</span></h2>
    <p class="nc-lead" style="max-width:40rem;">
      Keynotes, plenary sessions, partner presentations, the CeiGo launch, and
      the leadership panel will be available through the official conference live
      stream on event days.
    </p>

    <div class="nc-stream-grid">
      <div class="nc-stream-stage">
        <div class="nc-stream-badge">
          <span class="nc-live-dot" style="background:#fff;box-shadow:none;"></span>
          Available on event days
        </div>
        <h3>Official conference stream</h3>
        <p>
          Follow CE-Logic on Facebook for the official stream. The live link
          activates when programming begins on July 30-31, 2026.
        </p>
        <a
          class="nc-btn nc-btn-gold"
          href={STREAM_URL}
          id="cel-nc-watch-live"
          target="_blank"
          rel="noopener noreferrer"
        >
          Watch on Facebook
        </a>
        <p class="nc-stream-note">Stream link activates on event day</p>
      </div>
      <aside class="nc-stream-aside">
        <h4>Program coverage</h4>
        <ul>
          <li>
            <strong>Day 1</strong>
            Opening keynote, strategy sessions, and CeiGo launch
          </li>
          <li>
            <strong>Day 2</strong>
            AI services session, leadership panel, and closing
          </li>
          <li>
            <strong>Partners</strong>
            Featured sponsor and partner presentations
          </li>
          <li>
            <strong>Access</strong>
            Official stream via CE-Logic Facebook
          </li>
        </ul>
        <a
          class="nc-btn nc-btn-outline-light"
          href="#cel-nc-speakers"
          style="width:100%;"
        >
          View speakers
        </a>
      </aside>
    </div>
  </div>
</section>
