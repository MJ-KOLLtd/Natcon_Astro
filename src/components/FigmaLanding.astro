---
import Subnav from './Subnav.astro';
---

<div class="cel-nc-figma">
  <a class="skip" href="#cel-nc-highlights">Skip to main content</a>

  <div class="cel-nc nc-figma-nav">
    <Subnav homeHref="#hero" />
  </div>

  <section class="screen" id="hero" aria-label="Conference hero">
    <div class="screen-frame">
      <picture>
        <source
          media="(min-width: 641px)"
          srcset="/assets/hero.webp 1600w, /assets/hero@2x.webp 2400w"
          type="image/webp"
          sizes="100vw"
        />
        <img
          src="/assets/hero-mobile.webp"
          srcset="/assets/hero-mobile.webp 828w, /assets/hero-mobile@2x.webp 1242w"
          width="828"
          height="1472"
          sizes="100vw"
          alt="18th CE-Logic National Conference. CE-Logic in partnership with The University Library, University of the Philippines Diliman. Empowering Data Champions for Sustainable, Future-Ready, and Globally Competitive Education. July 30-31, 2026 · Seda Vertis North, Quezon City, Manila."
          decoding="async"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
    </div>
  </section>
</div>