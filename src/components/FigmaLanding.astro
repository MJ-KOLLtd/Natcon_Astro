---
import { SEO_TITLE, SITE_NAME } from '../data/site';
import Subnav from './Subnav.astro';
---

<div class="cel-nc-figma">
  <a class="skip" href="#cel-nc-highlights">Skip to main content</a>

  <div class="cel-nc nc-figma-nav">
    <Subnav homeHref="#hero" />
  </div>

  <section class="screen" id="hero" aria-labelledby="cel-nc-hero-title">
    <h1 id="cel-nc-hero-title" class="nc-sr-only">
      {SEO_TITLE}
    </h1>
    <div class="screen-frame">
      <picture>
        <source
          media="(min-width: 641px)"
          srcset="/assets/hero.webp 1600w, /assets/hero@2x.webp 2400w"
          type="image/webp"
          sizes="100vw"
        />
        <img
          src="/assets/hero-mobile.webp"
          srcset="/assets/hero-mobile.webp 828w, /assets/hero-mobile@2x.webp 1242w"
          width="828"
          height="1472"
          sizes="100vw"
          alt={`${SITE_NAME} 2026, the 18th CE-Logic National Conference in partnership with the University Library, UP Diliman. July 30-31, 2026 at Seda Vertis North, Quezon City.`}
          decoding="async"
          loading="eager"
          fetchpriority="high"
        />
      </picture>
    </div>
  </section>
</div>