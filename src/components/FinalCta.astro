---
import { CONFERENCE_NAME, SITE_NAME } from '../data/site';

const brandLogos = [
  { src: '/assets/ce-logic-logo.webp', alt: 'CE-Logic', width: 220, height: 40 },
  { src: '/assets/ceals-logo.webp', alt: 'C&E Adaptive Learning Solutions', width: 200, height: 65 },
];

const institutional = [
  { src: '/assets/partner-up-library.webp', alt: 'UP Library', width: 120, height: 120 },
  { src: '/assets/partner-plai.webp', alt: 'PLAI', width: 120, height: 120 },
  { src: '/assets/partner-paarl.webp', alt: 'PAARL', className: 'is-paarl', width: 100, height: 96 },
];

const sponsors = [
  { src: '/assets/partner-superhuman-071626.webp', alt: 'Superhuman', className: 'is-wordmark', width: 160, height: 48 },
  { src: '/assets/partner-scientific-071626.webp', alt: 'Scientific e-Resources', className: 'is-wordmark is-compact', width: 160, height: 48 },
  { src: '/assets/partner-gale-071626.webp', alt: 'Gale', className: 'is-wordmark', width: 160, height: 48 },
  { src: '/assets/partner-mcgraw.webp', alt: 'McGraw Hill', className: 'is-wordmark', width: 160, height: 48 },
  { src: '/assets/partner-cambridge-071626.webp', alt: 'Cambridge', className: 'is-wordmark', width: 160, height: 48 },
  { src: '/assets/partner-knimbus-071626.webp', alt: 'Knimbus', className: 'is-wordmark', width: 160, height: 48 },
];
---

<section class="nc-final">
  <div class="nc-container nc-final-scroll">
    <div class="nc-final-glass nc-final-panel">
      <div class="nc-final-col nc-final-intro">
        <p class="nc-final-eyebrow">{SITE_NAME} · {CONFERENCE_NAME}</p>
        <h2 class="nc-final-title">
          <span class="nc-final-date">July 30–31, 2026</span>
          <span class="nc-final-headline">Live Stream Access</span>
        </h2>
        <p class="nc-final-copy">
          Featured speakers, partners and sponsors, and event-day live streaming are
          available on this page. Registration is not required to view the stream.
        </p>
        <div class="nc-btn-row nc-final-actions">
          <a
            class="nc-btn nc-btn-gold"
            href="https://www.facebook.com/celogic"
            target="_blank"
            rel="noopener noreferrer"
          >Live stream</a>
          <a class="nc-btn nc-btn-outline-light" href="#cel-nc-partners">
            Partners and sponsors
          </a>
        </div>
      </div>

      <div
        class="nc-final-col nc-final-logos"
        aria-label="Conference brands, partners, and sponsors"
      >
        <div class="nc-final-logo-group">
          <p class="nc-final-logos-label">Presented by</p>
          <ul class="nc-final-logo-row is-brand">
            {
              brandLogos.map((l) => (
                <li>
                  <img src={l.src} alt={l.alt} width={l.width} height={l.height} loading="lazy" decoding="async" />
                </li>
              ))
            }
          </ul>
        </div>

        <div class="nc-final-logo-group">
          <p class="nc-final-logos-label">In partnership &amp; endorsed by</p>
          <ul class="nc-final-logo-row is-seals">
            {
              institutional.map((l) => (
                <li class:list={[l.className]}>
                  <img src={l.src} alt={l.alt} width={l.width} height={l.height} loading="lazy" decoding="async" />
                </li>
              ))
            }
          </ul>
        </div>

        <div class="nc-final-logo-group">
          <p class="nc-final-logos-label">Sponsors &amp; partners</p>
          <ul class="nc-final-logo-row is-sponsors">
            {
              sponsors.map((l) => (
                <li class:list={[l.className]}>
                  <img src={l.src} alt={l.alt} width={l.width} height={l.height} loading="lazy" decoding="async" />
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>

    <p class="nc-fine nc-final-fine">
      CE-Logic National Conference · C&amp;E Adaptive Learning Solutions
    </p>
  </div>
</section>