---
const PLACEHOLDER = '/assets/speaker-placeholder.webp';

function speakerPhoto(stem: string) {
  return {
    src: `/assets/speakers/${stem}.webp`,
    srcset: `/assets/speakers/${stem}.webp 480w, /assets/speakers/${stem}@2x.webp 600w`,
  };
}

const speakers = [
  {
    tag: 'Keynote',
    name: 'Dr. Milabel E. Ho',
    role: 'Executive Director, AACCUP',
    ...speakerPhoto('milabel-ho'),
  },
  {
    tag: 'Welcome · Session',
    name: 'Ms. Elvira B. Lapuz',
    role: 'University Librarian, UP Diliman',
    ...speakerPhoto('elvira-lapuz'),
  },
  {
    tag: 'PLAI · Session',
    name: 'Dr. Maria Pretty Lay T. Abdala',
    role: 'Dean, BulSU · President, PLAI',
    ...speakerPhoto('maria-pretty-lay-abdala'),
  },
  {
    tag: 'Session',
    name: 'Janice D.C. Peñaflor',
    role: 'Associate Director, DLSU Libraries',
    ...speakerPhoto('janice-dc-penaflor'),
  },
  {
    tag: 'Session',
    name: 'Efren M. Torres, Jr.',
    role: 'Access & Resource Management, DLSU Libraries',
    ...speakerPhoto('efren-torres'),
  },
  {
    tag: 'Session',
    name: 'Prof. Dan Anthony Dorado',
    role: 'UP School of Library and Information Studies',
    ...speakerPhoto('dan-anthony-dorado'),
  },
  {
    tag: 'Panel',
    name: 'Ms. Joenabie Arevalo',
    role: 'University Librarian, Ateneo de Manila University',
    ...speakerPhoto('joenabie-arevalo'),
    photoPosition: 'center 8%',
  },
  {
    tag: 'Panel',
    name: 'Edgardo B. Quiros, RL',
    role: 'Assistant Director, National Library of the Philippines',
    ...speakerPhoto('edgardo-quiros'),
  },
  {
    tag: 'CeiGo',
    name: 'Dr. Diu Seng (“DS”) See',
    role: 'Business & Sales Enablement Manager, iGroup',
    ...speakerPhoto('diu-seng-ds-see'),
  },
  {
    tag: 'Partner',
    name: 'Mike Shen',
    role: 'Channel Partner Manager APAC, Grammarly by Superhuman',
    ...speakerPhoto('mike-shen'),
  },
  {
    tag: 'Partner',
    name: 'Sean Chia',
    role: 'Senior Regional Account Manager, Gale / Cengage',
    ...speakerPhoto('sean-chia'),
