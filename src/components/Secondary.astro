---
import BtnArrow from './BtnArrow.astro';
---

<section class="nc-secondary">
  <div class="nc-container">
    <div class="nc-secondary-grid">
      <p class="nc-secondary-q">About the CE-Logic National Conference</p>
      <div class="nc-secondary-a">
        <h2 class="nc-h3">Strategy, technology, and research impact</h2>
        <p>
          The CE-Logic National Conference convenes academic library leaders,
          solution partners, and higher education stakeholders for a program
          focused on strategic planning, digital services, and research
          performance. Sessions will be available via live stream on event days.
        </p>
        <div class="nc-btn-row" style="margin-top:1.25rem;">
          <a class="nc-btn nc-btn-primary" href="#cel-nc-stream">
            Live stream access
            <BtnArrow />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
