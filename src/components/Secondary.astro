---
import { SITE_NAME } from '../data/site';
import BtnArrow from './BtnArrow.astro';

const FB_STREAM = 'https://www.facebook.com/celogic';
---

<section class="nc-secondary" id="cel-nc-about">
  <div class="nc-container">
    <div class="nc-secondary-grid">
      <div class="nc-secondary-a">
        <h2 class="nc-h3 nc-title-case">Strategy, Technology, and Research Impact</h2>
        <p>
          <strong>{SITE_NAME}</strong> convenes academic library leaders,
          solution partners, and higher education stakeholders for the 18th
          CE-Logic National Conference, a program focused on strategic planning,
          digital services, and research performance. Sessions will be available
          via live stream on event days.
        </p>
        <div class="nc-btn-row" style="margin-top:1.25rem;">
          <a
            class="nc-btn nc-btn-primary"
            href={FB_STREAM}
            target="_blank"
            rel="noopener noreferrer"
          >
            Live stream access
            <BtnArrow />
          </a>
        </div>
        <p class="nc-secondary-note">
          Stream link activates on event day · July 30-31, 2026
        </p>
      </div>
    </div>
  </div>
</section>
