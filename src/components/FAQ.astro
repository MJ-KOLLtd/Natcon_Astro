---
const faqs = [
  {
    open: true,
    q: 'How may I access the live stream?',
    a: 'The official stream is hosted on the CE-Logic Facebook page (facebook.com/celogic). The live stream link activates on event days, July 30-31, 2026. You may also use the Live stream control in the page navigation.',
  },
  {
    open: false,
    q: 'What sessions will be streamed?',
    a: 'Day 1 includes the opening keynote, strategy sessions, and the CeiGo launch. Day 2 includes the AI services session, leadership panel, and closing remarks. Partner presentations form part of the live program.',
  },
  {
    open: false,
    q: 'Who are the partners and sponsors?',
    a: 'Conference partners include iGroup (CeiGo launch), Grammarly by Superhuman, Gale, Part of Cengage Group, McGraw-Hill, and Scientific eResources. The conference is presented by CE-Logic, Inc., under C&E Adaptive Learning Solutions.',
  },
];
---

<section class="nc-section" id="cel-nc-faq">
  <div class="nc-container">
    <div class="nc-center" style="margin-bottom:2rem;">
      <h2 class="nc-h2">Frequently Asked Questions</h2>
      <p class="nc-lead">
        Information on live streaming, speakers, and conference partners.
      </p>
    </div>
    <div class="nc-faq">
      {
        faqs.map((faq) => (
          <details open={faq.open || undefined}>
            <summary>{faq.q}</summary>
            <p>{faq.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
